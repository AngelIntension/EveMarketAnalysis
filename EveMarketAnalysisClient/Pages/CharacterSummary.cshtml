@page
@model EveMarketAnalysisClient.Pages.CharacterSummaryModel
@using Microsoft.AspNetCore.Authorization
@attribute [Authorize]
@{
    ViewData["Title"] = "Character Summary";
}

<h2>Character Summary</h2>

@if (!string.IsNullOrEmpty(Model.ErrorMessage))
{
    <div class="alert alert-danger" role="alert">
        <p>@Model.ErrorMessage</p>
    </div>
}
else if (Model.Summary != null)
{
    <div class="row mb-4">
        <div class="col-auto">
            <img src="@Model.Summary.PortraitUrl" alt="@Model.Summary.Name" class="rounded" width="128" height="128" />
        </div>
        <div class="col">
            <h3>@Model.Summary.Name</h3>
            <p class="text-muted">Data fetched: @Model.Summary.FetchedAt.ToString("g")</p>
        </div>
    </div>

    <h4>Skills</h4>
    @if (Model.Summary.SkillGroups.IsEmpty)
    {
        <p class="text-muted">No relevant skills found.</p>
    }
    else
    {
        @foreach (var group in Model.Summary.SkillGroups)
        {
            <div class="card mb-3">
                <div class="card-header">
                    <strong>@group.GroupName</strong>
                    <span class="badge bg-secondary ms-2">@group.TotalSp.ToString("N0") SP</span>
                </div>
                <ul class="list-group list-group-flush">
                    @foreach (var skill in group.Skills)
                    {
                        <li class="list-group-item d-flex justify-content-between">
                            <span>@skill.SkillName</span>
                            <span>
                                Level @skill.TrainedLevel
                                <small class="text-muted">(@skill.SkillPointsInSkill.ToString("N0") SP)</small>
                            </span>
                        </li>
                    }
                </ul>
            </div>
        }
    }

    <h4>Skill Queue</h4>
    @if (Model.Summary.SkillQueue.IsEmpty)
    {
        <p class="text-muted">No skills currently training.</p>
    }
    else
    {
        <table class="table">
            <thead>
                <tr>
                    <th>#</th>
                    <th>Skill</th>
                    <th>Target Level</th>
                    <th>Finish Date</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var entry in Model.Summary.SkillQueue)
                {
                    <tr>
                        <td>@(entry.QueuePosition + 1)</td>
                        <td>@entry.SkillName</td>
                        <td>@entry.FinishedLevel</td>
                        <td>@(entry.FinishDate?.ToString("g") ?? "Unknown")</td>
                    </tr>
                }
            </tbody>
        </table>
    }

    @if (Model.Summary.IndustryJobCount.HasValue || Model.Summary.BlueprintCount.HasValue)
    {
        <h4>Industry</h4>
        <div class="row">
            @if (Model.Summary.IndustryJobCount.HasValue)
            {
                <div class="col-auto">
                    <div class="card">
                        <div class="card-body text-center">
                            <h5 class="card-title">@(Model.Summary.IndustryJobCount == 0 ? "None active" : Model.Summary.IndustryJobCount.ToString())</h5>
                            <p class="card-text">Industry Jobs</p>
                        </div>
                    </div>
                </div>
            }
            @if (Model.Summary.BlueprintCount.HasValue)
            {
                <div class="col-auto">
                    <div class="card">
                        <div class="card-body text-center">
                            <h5 class="card-title">@(Model.Summary.BlueprintCount == 0 ? "None owned" : Model.Summary.BlueprintCount.ToString())</h5>
                            <p class="card-text">Blueprints</p>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
}
else
{
    <p>Loading character data...</p>
}
