@page
@model EveMarketAnalysisClient.Pages.CharacterSummaryModel
@using Microsoft.AspNetCore.Authorization
@attribute [Authorize]
@{
    ViewData["Title"] = "Character Summary";
}

<h2>Character Summary</h2>

@if (!string.IsNullOrEmpty(Model.ErrorMessage))
{
    <div class="alert alert-danger" role="alert">
        <p>@Model.ErrorMessage</p>
    </div>
}
else
{
    <div id="error-alert" class="alert alert-danger d-none" role="alert"></div>

    <div class="row mb-4">
        <div class="col-auto">
            <div id="portrait-placeholder" class="skeleton skeleton-portrait rounded"></div>
            <img id="portrait" class="rounded d-none" width="128" height="128" alt="@Model.CharacterName" />
        </div>
        <div class="col">
            <h3>@Model.CharacterName</h3>
            <p id="fetched-at" class="text-muted"><span class="skeleton skeleton-text" style="width:200px"></span></p>
        </div>
    </div>

    <h4>Skills</h4>
    <div id="skills-section">
        @for (var i = 0; i < 3; i++)
        {
            <div class="card mb-3">
                <div class="card-header">
                    <span class="skeleton skeleton-text" style="width:140px"></span>
                    <span class="skeleton skeleton-text ms-2" style="width:80px"></span>
                </div>
                <ul class="list-group list-group-flush">
                    @for (var j = 0; j < 4; j++)
                    {
                        <li class="list-group-item d-flex justify-content-between">
                            <span class="skeleton skeleton-text" style="width:160px"></span>
                            <span class="skeleton skeleton-text" style="width:100px"></span>
                        </li>
                    }
                </ul>
            </div>
        }
    </div>

    <h4>Skill Queue</h4>
    <div id="queue-section">
        <table class="table">
            <thead>
                <tr>
                    <th>#</th>
                    <th>Skill</th>
                    <th>Target Level</th>
                    <th>Finish Date</th>
                </tr>
            </thead>
            <tbody>
                @for (var i = 0; i < 5; i++)
                {
                    <tr>
                        <td><span class="skeleton skeleton-text" style="width:20px"></span></td>
                        <td><span class="skeleton skeleton-text" style="width:140px"></span></td>
                        <td><span class="skeleton skeleton-text" style="width:30px"></span></td>
                        <td><span class="skeleton skeleton-text" style="width:120px"></span></td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    <div id="industry-section" class="d-none">
        <h4>Industry</h4>
        <div id="industry-cards" class="row"></div>
    </div>
}

@section Scripts {
    <script>
        (function () {
            const summaryUrl = '@Url.Page("/CharacterSummary", "Summary")';
            if (!summaryUrl) return;

            fetch(summaryUrl, { credentials: 'same-origin' })
                .then(function (res) {
                    if (!res.ok) throw new Error('HTTP ' + res.status);
                    return res.json();
                })
                .then(function (data) {
                    if (data.error) {
                        showError(data.error);
                        return;
                    }
                    renderSummary(data);
                })
                .catch(function (err) {
                    showError('Failed to load character data: ' + err.message);
                });

            function showError(msg) {
                var el = document.getElementById('error-alert');
                el.textContent = msg;
                el.classList.remove('d-none');
                document.getElementById('skills-section').innerHTML = '';
                document.getElementById('queue-section').innerHTML = '';
            }

            function esc(str) {
                var d = document.createElement('div');
                d.textContent = str;
                return d.innerHTML;
            }

            function formatNumber(n) {
                return Number(n).toLocaleString();
            }

            function renderSummary(s) {
                // Portrait
                var placeholder = document.getElementById('portrait-placeholder');
                var img = document.getElementById('portrait');
                img.src = s.portraitUrl;
                img.onload = function () {
                    placeholder.classList.add('d-none');
                    img.classList.remove('d-none');
                };

                // Fetched at
                var fetchedAt = new Date(s.fetchedAt);
                document.getElementById('fetched-at').textContent =
                    'Data fetched: ' + fetchedAt.toLocaleString();

                // Skills
                var skillsHtml = '';
                if (!s.skillGroups || s.skillGroups.length === 0) {
                    skillsHtml = '<p class="text-muted">No relevant skills found.</p>';
                } else {
                    for (var i = 0; i < s.skillGroups.length; i++) {
                        var g = s.skillGroups[i];
                        skillsHtml += '<div class="card mb-3"><div class="card-header">' +
                            '<strong>' + esc(g.groupName) + '</strong>' +
                            '<span class="badge bg-secondary ms-2">' + formatNumber(g.totalSp) + ' SP</span>' +
                            '</div><ul class="list-group list-group-flush">';
                        for (var j = 0; j < g.skills.length; j++) {
                            var sk = g.skills[j];
                            skillsHtml += '<li class="list-group-item d-flex justify-content-between">' +
                                '<span>' + esc(sk.skillName) + '</span>' +
                                '<span>Level ' + sk.trainedLevel +
                                ' <small class="text-muted">(' + formatNumber(sk.skillPointsInSkill) + ' SP)</small></span></li>';
                        }
                        skillsHtml += '</ul></div>';
                    }
                }
                document.getElementById('skills-section').innerHTML = skillsHtml;

                // Skill Queue
                var queueHtml = '';
                if (!s.skillQueue || s.skillQueue.length === 0) {
                    queueHtml = '<p class="text-muted">No skills currently training.</p>';
                } else {
                    queueHtml = '<table class="table"><thead><tr><th>#</th><th>Skill</th><th>Target Level</th><th>Finish Date</th></tr></thead><tbody>';
                    for (var k = 0; k < s.skillQueue.length; k++) {
                        var q = s.skillQueue[k];
                        var finishDate = q.finishDate ? new Date(q.finishDate).toLocaleString() : 'Unknown';
                        queueHtml += '<tr><td>' + (q.queuePosition + 1) + '</td>' +
                            '<td>' + esc(q.skillName) + '</td>' +
                            '<td>' + q.finishedLevel + '</td>' +
                            '<td>' + esc(finishDate) + '</td></tr>';
                    }
                    queueHtml += '</tbody></table>';
                }
                document.getElementById('queue-section').innerHTML = queueHtml;

                // Industry
                var hasIndustry = s.industryJobCount != null || s.blueprintCount != null;
                if (hasIndustry) {
                    var indSection = document.getElementById('industry-section');
                    indSection.classList.remove('d-none');
                    var cardsHtml = '';
                    if (s.industryJobCount != null) {
                        var jobText = s.industryJobCount === 0 ? 'None active' : String(s.industryJobCount);
                        cardsHtml += '<div class="col-auto"><div class="card"><div class="card-body text-center">' +
                            '<h5 class="card-title">' + esc(jobText) + '</h5>' +
                            '<p class="card-text">Industry Jobs</p></div></div></div>';
                    }
                    if (s.blueprintCount != null) {
                        var bpText = s.blueprintCount === 0 ? 'None owned' : String(s.blueprintCount);
                        cardsHtml += '<div class="col-auto"><div class="card"><div class="card-body text-center">' +
                            '<h5 class="card-title">' + esc(bpText) + '</h5>' +
                            '<p class="card-text">Blueprints</p></div></div></div>';
                    }
                    document.getElementById('industry-cards').innerHTML = cardsHtml;
                }
            }
        })();
    </script>
}
